# macOS noise
.DS_Store

# Data-pipeline download cache (reproducible; full-page copies of third-party
# sites don't belong in a public repo). Note: fetch_mortality.py reads a
# browser-saved SSA page from here -- re-save it manually if you ever need to
# regenerate js/mortality-data.js (the generated file IS committed).
tools/.cache/

# Server-local secrets (cloudflare tunnel token, read by docker-compose.yaml
# variable substitution) -- never committed
.env

# Server-local deployment config (paths/UIDs/names -- no secrets; the repo
# ships config.webswr.example). Lives in the webroot so the nightly copy can
# never overwrite the operator's edits.
config.webswr

# Scratch
*.tmp
